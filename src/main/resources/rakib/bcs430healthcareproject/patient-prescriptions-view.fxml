<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.PatientPrescriptionsController"
            stylesheets="@app.css">

    <top>
        <HBox style="-fx-background-color: #0F766E; -fx-padding: 18 24; -fx-alignment: center-left; -fx-spacing: 15;">
            <Button text="Back"
                    onAction="#onBack"
                    style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16;" />
            <Label text="My Prescriptions"
                   style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </top>

    <center>
        <VBox style="-fx-background-color: #F8FAFC; -fx-padding: 24; -fx-spacing: 16;">
            <Label text="View the medications your doctor has sent and whether the pharmacy has filled them."
                   style="-fx-text-fill: #334155; -fx-font-size: 14;" />
            <TextField fx:id="medicationSearchField"
                       promptText="Search by medication name"
                       style="-fx-background-radius: 10; -fx-padding: 10 12; -fx-font-size: 13;" />
            <Label fx:id="statusLabel"
                   style="-fx-text-fill: #0F766E; -fx-font-size: 12; -fx-font-weight: bold;" />
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <content>
                    <VBox fx:id="prescriptionsListVBox" spacing="14" style="-fx-padding: 4;" />
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
