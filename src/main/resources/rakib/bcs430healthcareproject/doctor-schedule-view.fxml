<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity"
            maxWidth="-Infinity"
            minHeight="600.0"
            minWidth="900.0"
            prefHeight="700.0"
            prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/19"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="rakib.bcs430healthcareproject.DoctorScheduleController"
            stylesheets="@styles.css">

    <top>
        <HBox alignment="CENTER_LEFT"
              prefHeight="60.0"
              spacing="10.0"
              style="-fx-background-color: #57ad44;"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <children>
                <Label prefHeight="60.0" text="Doctor Schedule" textFill="WHITE">
                    <font>
                        <Font name="Segoe UI Bold" size="20.0" />
                    </font>
                    <HBox.margin>
                        <Insets right="40.0" />
                    </HBox.margin>
                </Label>

                <Button mnemonicParsing="false"
                        onAction="#onBack"
                        prefHeight="60.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"
                        text="Dashboard">
                    <padding>
                        <Insets left="20.0" right="20.0" />
                    </padding>
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>

                <Button mnemonicParsing="false"
                        prefHeight="60.0"
                        style="-fx-background-color: #2d9149; -fx-text-fill: white; -fx-border-color: #3498DB; -fx-border-width: 0 0 4 0;"
                        text="Schedule Management">
                    <padding>
                        <Insets left="20.0" right="20.0" />
                    </padding>
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>

                <Button fx:id="btnReschedule"
                        mnemonicParsing="false"
                        onAction="#handleReschedule"
                        prefHeight="60.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"
                        text="Reschedule">
                    <padding>
                        <Insets left="20.0" right="20.0" />
                    </padding>
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
            </children>
        </HBox>
    </top>

    <center>
        <VBox prefHeight="200.0"
              prefWidth="100.0"
              spacing="20.0"
              style="-fx-background-color: #ECF0F1;"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="200.0" spacing="15.0">
                    <children>
                        <VBox>
                            <children>
                                <Label text="Daily Schedule" textFill="#2c3e50">
                                    <font>
                                        <Font name="Segoe UI Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Label text="HealthCare Management" textFill="#7f8c8d" />
                            </children>
                        </VBox>
                        <Separator orientation="VERTICAL" prefHeight="200.0" />
                        <Label text="Date:" />
                        <DatePicker fx:id="scheduleDatePicker"
                                    onAction="#handleDateChange"
                                    promptText="Select Date" />
                    </children>
                </HBox>

                <TableView fx:id="appointmentTable"
                           prefHeight="600.0"
                           prefWidth="600.0"
                           stylesheets="@styles.css"
                           VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTime" prefWidth="85.0" text="Time" />
                        <TableColumn fx:id="colPatient" prefWidth="180.0" text="Patient Name" />
                        <TableColumn fx:id="colType" prefWidth="120.0" text="Type" />
                        <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                        <TableColumn fx:id="colNotes" prefWidth="200.0" text="Notes" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button fx:id="btnMessage"
                                mnemonicParsing="false"
                                onAction="#handleMessagePatient"
                                style="-fx-background-color: #F39C12; -fx-text-fill: white;"
                                text="Message Patient" />
                        <Button fx:id="btnPrescription"
                                mnemonicParsing="false"
                                onAction="#handleSendPrescription"
                                style="-fx-background-color: #8E44AD; -fx-text-fill: white;"
                                text="Send Prescription" />
                        <Button mnemonicParsing="false"
                                onAction="#handleCancelSelected"
                                style="-fx-background-color: #E74C3C; -fx-text-fill: white;"
                                text="Cancel Selected" />
                        <Button mnemonicParsing="false"
                                onAction="#handleMarkComplete"
                                style="-fx-background-color: #27AE60; -fx-text-fill: white;"
                                text="Mark as Complete" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <right>
        <VBox prefHeight="700.0"
              prefWidth="280.0"
              spacing="15.0"
              style="-fx-background-color: white; -fx-border-color: #BDC3C7; -fx-border-width: 0 0 0 1;"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="New Schedule" textFill="#2c3e50">
                    <font>
                        <Font name="Segoe UI Bold" size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>

                <Label text="Patient Name" textFill="#7f8c8d" />
                <TextField fx:id="txtName" promptText="Enter full name" style="-fx-background-radius: 5;" />

                <Label text="Contact Number" textFill="#7f8c8d" />
                <TextField fx:id="txtContact" promptText="(555) 000-0000" style="-fx-background-radius: 5;" />

                <HBox spacing="10.0">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Time" textFill="#7f8c8d" />
                                <ComboBox fx:id="comboTime" editable="true" prefWidth="150.0" promptText="09:00 AM" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Duration" textFill="#7f8c8d" />
                                <ComboBox fx:id="comboDuration" prefWidth="150.0" promptText="30 min" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Label text="Schedule Type" textFill="#7f8c8d" />
                <ComboBox fx:id="comboType" maxWidth="1.7976931348623157E308" promptText="Check-up" />

                <Label text="Reason / Notes" textFill="#7f8c8d" />
                <TextArea fx:id="txtReason" prefHeight="100.0" prefWidth="200.0" promptText="Brief description..." wrapText="true" />

                <Separator prefWidth="200.0">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Separator>

                <Button fx:id="btnBookSchedule"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        prefHeight="40.0"
                        style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-cursor: hand;"
                        text="Book Schedule">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
            </children>
        </VBox>
    </right>
</BorderPane>
