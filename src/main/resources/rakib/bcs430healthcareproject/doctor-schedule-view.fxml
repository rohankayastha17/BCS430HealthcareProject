<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650.0"
            prefWidth="1000.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="rakib.bcs430healthcareproject.DoctorScheduleController"
            stylesheets="@app.css"
            style="-fx-background-color: #F8FAFC;">

    <top>
        <VBox spacing="0">

            <HBox alignment="CENTER_LEFT"
                  spacing="15.0"
                  style="-fx-background-color: #0F766E; -fx-padding: 14 20;">
                <Label text="HealthConnect"
                       style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" />

                <Region HBox.hgrow="ALWAYS" />

                <Label text="Doctor Schedule"
                       style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" />

                <Button text="Back to Dashboard"
                        onAction="#onBack"
                        style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 14;" />
            </HBox>

            <HBox style="-fx-background-color: #F0FDFA; -fx-padding: 8 20; -fx-spacing: 10; -fx-border-color: #D1FAE5; -fx-border-width: 0 0 1 0;">

                <Button text="Schedule Management"
                        style="-fx-background-color: #0F766E; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 18; -fx-padding: 8 16;" />

                <Button fx:id="btnReschedule"
                        mnemonicParsing="false"
                        onAction="#handleReschedule"
                        text="Reschedule Selected"
                        style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 12; -fx-font-weight: bold; -fx-border-color: #14B8A6; -fx-border-radius: 18; -fx-background-radius: 18; -fx-padding: 8 16;" />
            </HBox>

        </VBox>
    </top>

    <center>
        <HBox spacing="16.0"
              style="-fx-padding: 16; -fx-background-color: #F8FAFC;">

            <VBox spacing="16.0" HBox.hgrow="ALWAYS">

                <VBox spacing="6.0"
                      style="-fx-background-color: linear-gradient(to right, #0F766E, #14B8A6); -fx-background-radius: 14; -fx-padding: 18;">
                    <Label text="Daily Schedule"
                           style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" />
                    <Label text="Review appointments, update visits, and manage your day from one place."
                           style="-fx-text-fill: #CCFBF1; -fx-font-size: 13;" />

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Date:"
                               style="-fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;" />
                        <DatePicker fx:id="scheduleDatePicker"
                                    onAction="#handleDateChange"
                                    prefWidth="170"
                                    style="-fx-background-radius: 8;" />
                    </HBox>
                </VBox>

                <VBox spacing="12.0"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 14; -fx-border-color: #D1FAE5; -fx-border-radius: 14;"
                      VBox.vgrow="ALWAYS">

                    <Label text="Appointments"
                           style="-fx-text-fill: #0F766E; -fx-font-size: 16; -fx-font-weight: bold;" />

                    <TableView fx:id="appointmentTable"
                               VBox.vgrow="ALWAYS"
                               prefHeight="360.0"
                               style="-fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                        <columns>
                            <TableColumn fx:id="colTime" prefWidth="90.0" text="Time" />
                            <TableColumn fx:id="colPatient" prefWidth="180.0" text="Patient Name" />
                            <TableColumn fx:id="colType" prefWidth="120.0" text="Type" />
                            <TableColumn fx:id="colStatus" prefWidth="110.0" text="Status" />
                            <TableColumn fx:id="colNotes" prefWidth="220.0" text="Notes" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>

                    <HBox alignment="CENTER_RIGHT" spacing="8.0">
                        <Button fx:id="btnMessage"
                                mnemonicParsing="false"
                                onAction="#handleMessagePatient"
                                text="Message"
                                style="-fx-background-color: #F59E0B; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 14;" />

                        <Button fx:id="btnPrescription"
                                mnemonicParsing="false"
                                onAction="#handleSendPrescription"
                                text="Prescription"
                                style="-fx-background-color: #8B5CF6; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 14;" />

                        <Button fx:id="btnEditPatientProfile"
                                mnemonicParsing="false"
                                onAction="#handleEditPatientProfile"
                                text="Edit Patient"
                                style="-fx-background-color: #0F766E; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 14;" />

                        <Button mnemonicParsing="false"
                                onAction="#handleCancelSelected"
                                text="Cancel"
                                style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 14;" />

                        <Button mnemonicParsing="false"
                                onAction="#handleMarkComplete"
                                text="Complete"
                                style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 14;" />
                    </HBox>
                </VBox>
            </VBox>

            <VBox prefWidth="255.0"
                  maxWidth="255.0"
                  spacing="10.0"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 16; -fx-border-color: #D1FAE5; -fx-border-radius: 14;">

                <Label text="Schedule Form"
                       style="-fx-text-fill: #0F766E; -fx-font-size: 16; -fx-font-weight: bold;" />

                <Label text="Patient Name"
                       style="-fx-text-fill: #475569; -fx-font-size: 12; -fx-font-weight: bold;" />
                <TextField fx:id="txtName"
                           promptText="Enter full name"
                           style="-fx-background-radius: 8; -fx-border-radius: 8;" />

                <Label text="Contact Number"
                       style="-fx-text-fill: #475569; -fx-font-size: 12; -fx-font-weight: bold;" />
                <TextField fx:id="txtContact"
                           promptText="(555) 000-0000"
                           style="-fx-background-radius: 8; -fx-border-radius: 8;" />

                <HBox spacing="8.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Time"
                               style="-fx-text-fill: #475569; -fx-font-size: 12; -fx-font-weight: bold;" />
                        <ComboBox fx:id="comboTime"
                                  editable="true"
                                  maxWidth="1.7976931348623157E308"
                                  promptText="09:00 AM"
                                  style="-fx-background-radius: 8;" />
                    </VBox>

                    <VBox spacing="5.0" prefWidth="90.0">
                        <Label text="Duration"
                               style="-fx-text-fill: #475569; -fx-font-size: 12; -fx-font-weight: bold;" />
                        <ComboBox fx:id="comboDuration"
                                  maxWidth="1.7976931348623157E308"
                                  promptText="30 min"
                                  style="-fx-background-radius: 8;" />
                    </VBox>
                </HBox>

                <Label text="Schedule Type"
                       style="-fx-text-fill: #475569; -fx-font-size: 12; -fx-font-weight: bold;" />
                <ComboBox fx:id="comboType"
                          maxWidth="1.7976931348623157E308"
                          promptText="Check-up"
                          style="-fx-background-radius: 8;" />

                <Label text="Reason / Notes"
                       style="-fx-text-fill: #475569; -fx-font-size: 12; -fx-font-weight: bold;" />
                <TextArea fx:id="txtReason"
                          prefHeight="90.0"
                          promptText="Brief description..."
                          wrapText="true"
                          style="-fx-background-radius: 8; -fx-border-radius: 8;" />

                <Separator>
                    <VBox.margin>
                        <Insets top="2.0" bottom="2.0" />
                    </VBox.margin>
                </Separator>

                <Button fx:id="btnBookSchedule"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        prefHeight="40.0"
                        text="Book Schedule"
                        style="-fx-background-color: #0F766E; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" />
            </VBox>

        </HBox>
    </center>

</BorderPane>
