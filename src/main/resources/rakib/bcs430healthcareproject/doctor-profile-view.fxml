<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.DoctorProfileController"
            stylesheets="@app.css"
            styleClass="root page-shell">

    <!-- Top Header -->
    <top>
        <VBox>
            <HBox styleClass="top-header">
                <Button fx:id="backButton"
                        onAction="#onBack"
                        text="← Back"
                        styleClass="button header-btn" />

                <Label text="HealthConnect"
                       styleClass="top-header-title" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="titleLabel"
                       text="Doctor Profile"
                       styleClass="top-header-subtitle" />
            </HBox>

            <HBox styleClass="top-subbar">
                <Label fx:id="statusLabel"
                       text=""
                       styleClass="top-header-status"
                       visible="false"
                       managed="false" />
            </HBox>
        </VBox>
    </top>

    <!-- Main Content -->
    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    styleClass="scroll-pane clean-scroll">
            <content>
                <VBox styleClass="page-content">

                    <!-- Page Intro -->
                    <VBox styleClass="page-intro">
                        <Label text="Doctor Profile"
                               styleClass="page-intro-title" />
                        <Label text="Manage professional details, clinic information, office hours, and appointment preferences."
                               wrapText="true"
                               styleClass="page-intro-subtitle" />
                    </VBox>

                    <!-- Basic Information -->
                    <VBox styleClass="panel-card">
                        <Label text="Basic Information"
                               styleClass="panel-title" />

                        <VBox styleClass="form-section">
                            <Label text="Full Name *"
                                   styleClass="form-label" />
                            <TextField fx:id="nameField" promptText="Dr. Full Name" />
                        </VBox>

                        <HBox spacing="20">
                            <VBox styleClass="form-section" HBox.hgrow="ALWAYS">
                                <Label text="Specialty *"
                                       styleClass="form-label" />
                                <TextField fx:id="specialtyField" promptText="Cardiology, Dermatology, etc." />
                            </VBox>

                            <VBox styleClass="form-section" minWidth="180">
                                <Label text="License # (NPI/License)"
                                       styleClass="form-label" />
                                <TextField fx:id="licenseField" promptText="Optional" />
                            </VBox>
                        </HBox>

                        <VBox styleClass="form-section">
                            <Label text="Bio"
                                   styleClass="form-label" />
                            <TextArea fx:id="bioArea"
                                      promptText="Short description about your experience, education, and care approach..."
                                      wrapText="true"
                                      prefRowCount="4" />
                        </VBox>
                    </VBox>

                    <!-- Clinic / Location -->
                    <VBox styleClass="panel-card">
                        <Label text="Clinic / Location"
                               styleClass="panel-title" />

                        <VBox styleClass="form-section">
                            <Label text="Clinic Name *"
                                   styleClass="form-label" />
                            <TextField fx:id="clinicNameField" promptText="Clinic / Practice name" />
                        </VBox>

                        <VBox styleClass="form-section">
                            <Label text="Address *"
                                   styleClass="form-label" />
                            <TextField fx:id="addressField" promptText="123 Main St" />
                        </VBox>

                        <HBox spacing="20">
                            <VBox styleClass="form-section" HBox.hgrow="ALWAYS">
                                <Label text="City *"
                                       styleClass="form-label" />
                                <TextField fx:id="cityField" promptText="Farmingdale" />
                            </VBox>

                            <VBox styleClass="form-section" minWidth="90">
                                <Label text="State *"
                                       styleClass="form-label" />
                                <TextField fx:id="stateField" promptText="NY" />
                            </VBox>

                            <VBox styleClass="form-section" minWidth="120">
                                <Label text="ZIP *"
                                       styleClass="form-label" />
                                <TextField fx:id="zipField" promptText="11735" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Office Details -->
                    <VBox styleClass="panel-card">
                        <Label text="Office Details"
                               styleClass="panel-title" />

                        <HBox spacing="20">
                            <VBox styleClass="form-section" HBox.hgrow="ALWAYS">
                                <Label text="Phone"
                                       styleClass="form-label" />
                                <TextField fx:id="phoneField" promptText="(555) 555-5555" />
                            </VBox>

                            <VBox styleClass="form-section" HBox.hgrow="ALWAYS">
                                <Label text="Email (Public)"
                                       styleClass="form-label" />
                                <TextField fx:id="publicEmailField" promptText="office@example.com" />
                            </VBox>
                        </HBox>

                        <VBox styleClass="form-section">
                            <Label text="Accepting New Patients"
                                   styleClass="form-label" />
                            <CheckBox fx:id="acceptingNewPatientsCheck"
                                      text="Yes, accepting new patients" />
                        </VBox>

                        <VBox styleClass="form-section">
                            <Label text="Insurance Accepted"
                                   styleClass="form-label" />
                            <TextArea fx:id="insuranceArea"
                                      promptText="List insurances (comma-separated): Aetna, BCBS, United..."
                                      wrapText="true"
                                      prefRowCount="3" />
                        </VBox>

                        <VBox styleClass="form-section">
                            <Label text="Office Hours"
                                   styleClass="form-label" />

                            <GridPane hgap="12" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="22.0" />
                                    <ColumnConstraints percentWidth="78.0" />
                                </columnConstraints>

                                <Label text="Monday" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                <ComboBox fx:id="mondayField" GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="Infinity" />

                                <Label text="Tuesday" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                <ComboBox fx:id="tuesdayField" GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity" />

                                <Label text="Wednesday" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                <ComboBox fx:id="wednesdayField" GridPane.rowIndex="2" GridPane.columnIndex="1" maxWidth="Infinity" />

                                <Label text="Thursday" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                <ComboBox fx:id="thursdayField" GridPane.rowIndex="3" GridPane.columnIndex="1" maxWidth="Infinity" />

                                <Label text="Friday" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                                <ComboBox fx:id="fridayField" GridPane.rowIndex="4" GridPane.columnIndex="1" maxWidth="Infinity" />

                                <Label text="Saturday" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                                <ComboBox fx:id="saturdayField" GridPane.rowIndex="5" GridPane.columnIndex="1" maxWidth="Infinity" />

                                <Label text="Sunday" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                                <ComboBox fx:id="sundayField" GridPane.rowIndex="6" GridPane.columnIndex="1" maxWidth="Infinity" />
                            </GridPane>

                            <!-- legacy area kept hidden unless needed -->
                            <TextArea fx:id="hoursArea"
                                      promptText="Mon-Fri 9am-5pm&#10;Sat 9am-1pm..."
                                      wrapText="true"
                                      prefRowCount="3"
                                      visible="false"
                                      managed="false" />
                        </VBox>
                    </VBox>

                    <!-- Appointment Preferences -->
                    <VBox styleClass="panel-card">
                        <Label text="Appointment Preferences"
                               styleClass="panel-title" />

                        <VBox styleClass="form-section">
                            <Label text="Visit Type"
                                   styleClass="form-label" />
                            <ComboBox fx:id="visitTypeComboBox"
                                      promptText="Select visit type"
                                      maxWidth="Infinity" />
                        </VBox>

                        <VBox styleClass="form-section">
                            <Label text="Notes"
                                   styleClass="form-label" />
                            <TextArea fx:id="notesArea"
                                      promptText="Any additional notes for patients..."
                                      wrapText="true"
                                      prefRowCount="4" />
                        </VBox>
                    </VBox>

                    <VBox minHeight="30" />
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- Bottom Buttons -->
    <bottom>
        <HBox styleClass="footer-bar">
            <Button fx:id="editButton"
                    onAction="#onEdit"
                    text="Edit Profile"
                    styleClass="button primary-btn" />

            <Button fx:id="saveButton"
                    onAction="#onSave"
                    text="Save Changes"
                    styleClass="button success-btn"
                    managed="false"
                    visible="false" />

            <Button fx:id="cancelButton"
                    onAction="#onCancel"
                    text="Cancel"
                    styleClass="button cancel-btn"
                    managed="false"
                    visible="false" />
        </HBox>
    </bottom>
</BorderPane>