<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="rakib.bcs430healthcareproject.BookAppointmentController" stylesheets="@app.css">
    
    <!-- Top Bar -->
    <top>
        <VBox style="-fx-background-color: #2C3E50; -fx-padding: 15;">
            <HBox spacing="15" style="-fx-alignment: center-left;">
                <Button fx:id="backButton" onAction="#onBack" text="← Back" style="-fx-padding: 8; -fx-font-size: 12;"/>
                <Label text="Book Appointment" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" />
            </HBox>
            <Label fx:id="statusLabel" text="" style="-fx-text-fill: #27AE60; -fx-font-size: 11; -fx-padding: 5 0 0 0;" visible="false" managed="false"/>
        </VBox>
    </top>

    <!-- Center Content -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f9f9f9;">
            <VBox style="-fx-padding: 30; -fx-spacing: 20; -fx-background-color: #f9f9f9;">
                
                <!-- Doctor Information Section -->
                <VBox style="-fx-border-color: #E8E8E8; -fx-border-radius: 5; -fx-padding: 20; -fx-spacing: 15; -fx-background-color: white;">
                    <Label text="Doctor Information" style="-fx-text-fill: #2C3E50; -fx-font-size: 16; -fx-font-weight: bold;"/>
                    
                    <VBox spacing="5">
                        <Label text="Doctor Name" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11;"/>
                        <Label fx:id="doctorNameLabel" text="Dr. Name" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                    </VBox>
                    
                    <HBox spacing="20">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Specialty" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11;"/>
                            <Label fx:id="specialtyLabel" text="Specialty" style="-fx-font-size: 13; -fx-text-fill: #2C3E50;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Clinic" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11;"/>
                            <Label fx:id="clinicLabel" text="Clinic Name" style="-fx-font-size: 13; -fx-text-fill: #2C3E50;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Appointment Details Section -->
                <VBox style="-fx-border-color: #E8E8E8; -fx-border-radius: 5; -fx-padding: 20; -fx-spacing: 15; -fx-background-color: white;">
                    <Label text="Appointment Details" style="-fx-text-fill: #2C3E50; -fx-font-size: 16; -fx-font-weight: bold;"/>
                    
                    <!-- Date and Time Row -->
                    <HBox spacing="20">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Select Date *" style="-fx-text-fill: #333; -fx-font-weight: bold;"/>
                            <DatePicker fx:id="appointmentDatePicker" style="-fx-padding: 8;"/>
                        </VBox>
                        <VBox spacing="5" style="-fx-min-width: 200;">
                            <Label text="Select Time Slot *" style="-fx-text-fill: #333; -fx-font-weight: bold;"/>
                            <ComboBox fx:id="timeSlotComboBox" style="-fx-padding: 8;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Patient Info Section -->
                <VBox style="-fx-border-color: #E8E8E8; -fx-border-radius: 5; -fx-padding: 20; -fx-spacing: 10; -fx-background-color: white;">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <CheckBox fx:id="newPatientCheck" text="New Patient" />
                    </HBox>
                    <VBox spacing="5">
                        <Label text="Reason for Visit" style="-fx-text-fill: #2C3E50; -fx-font-size: 14; -fx-font-weight: bold;"/>
                        <TextField fx:id="reasonField" promptText="e.g. Annual checkup, sore throat" style="-fx-padding: 8;" />
                    </VBox>
                </VBox>

                <!-- Notes Section -->
                <VBox style="-fx-border-color: #E8E8E8; -fx-border-radius: 5; -fx-padding: 20; -fx-spacing: 10; -fx-background-color: white;">
                    <Label text="Additional Notes (Optional)" style="-fx-text-fill: #2C3E50; -fx-font-size: 14; -fx-font-weight: bold;"/>
                    <TextArea fx:id="notesArea" promptText="Describe any symptoms or concerns..." wrapText="true" style="-fx-padding: 8; -fx-control-inner-background: white; -fx-min-height: 100;" />
                </VBox>

                <!-- Spacer -->
                <VBox style="-fx-min-height: 30;" />
            </VBox>
        </ScrollPane>
    </center>

    <!-- Bottom Bar with Buttons -->
    <bottom>
        <HBox spacing="10" style="-fx-alignment: center-right; -fx-background-color: #f9f9f9; -fx-padding: 20;">
            <Button fx:id="cancelButton" onAction="#onCancel" text="Cancel"/>
            <Button fx:id="bookButton" onAction="#onBook" text="Book Appointment"/>
        </HBox>
    </bottom>

</BorderPane>
