<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.DoctorMessageController"
            stylesheets="@app.css">

    <!-- Top Header -->
    <top>
        <HBox style="-fx-background-color: #0F766E; -fx-padding: 18 24; -fx-alignment: center-left; -fx-spacing: 15;">
            <Button text="Back"
                    onAction="#onBack"
                    style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16;" />

            <Label text="Patient Messages"
                   style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;" />

            <Region HBox.hgrow="ALWAYS" />

            <Label fx:id="doctorNameLabel"
                   style="-fx-text-fill: #CCFBF1; -fx-font-size: 14; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <!-- Messenger Layout -->
    <center>
        <HBox style="-fx-background-color: #F8FAFC;">

            <!-- LEFT SIDEBAR -->
            <VBox prefWidth="300"
                  minWidth="280"
                  maxWidth="320"
                  style="-fx-background-color: white; -fx-border-color: #D1FAE5; -fx-border-width: 0 1 0 0; -fx-padding: 18; -fx-spacing: 14;">

                <Label text="Conversations"
                       style="-fx-text-fill: #0F172A; -fx-font-size: 18; -fx-font-weight: bold;" />

                <Label text="Patients you've messaged"
                       style="-fx-text-fill: #64748B; -fx-font-size: 12; -fx-font-weight: bold;" />

                <ListView fx:id="patientListView"
                          VBox.vgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-border-color: #D1FAE5; -fx-border-radius: 12; -fx-background-radius: 12;" />

                <Label fx:id="statusLabel"
                       wrapText="true"
                       style="-fx-text-fill: #0F766E; -fx-font-size: 12; -fx-font-weight: bold;" />
            </VBox>

            <!-- RIGHT CHAT AREA -->
            <VBox HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #F8FAFC;">

                <!-- Chat Header -->
                <VBox spacing="6"
                      style="-fx-background-color: white; -fx-border-color: #D1FAE5; -fx-border-width: 0 0 1 0; -fx-padding: 18 22;">
                    <Label fx:id="patientNameLabel"
                           text="Select a patient"
                           style="-fx-text-fill: #0F172A; -fx-font-size: 18; -fx-font-weight: bold;" />

                    <Label fx:id="patientInfoLabel"
                           text="Conversation details will appear here."
                           style="-fx-text-fill: #64748B; -fx-font-size: 13;" />
                </VBox>

                <!-- Messages -->
                <ScrollPane fx:id="messagesScrollPane"
                            fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <content>
                        <VBox fx:id="messagesVBox"
                              spacing="10"
                              style="-fx-padding: 20;" />
                    </content>
                </ScrollPane>

                <!-- Input Area -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-border-color: #D1FAE5; -fx-border-width: 1 0 0 0; -fx-padding: 16 18;">
                    <Label text="Write a Message"
                           style="-fx-text-fill: #0F172A; -fx-font-size: 15; -fx-font-weight: bold;" />

                    <TextArea fx:id="messageInputArea"
                              promptText="Type your message to the patient..."
                              wrapText="true"
                              prefRowCount="3"
                              style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-focus-color: #14B8A6; -fx-faint-focus-color: transparent;" />

                    <HBox spacing="10" style="-fx-alignment: center-right;">
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Clear"
                                onAction="#onClear"
                                style="-fx-background-color: #E2E8F0; -fx-text-fill: #0F172A; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16;" />
                        <Button fx:id="sendButton"
                                text="Send Text"
                                onAction="#onSendMessage"
                                style="-fx-background-color: #0EA5E9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 18;" />
                    </HBox>
                </VBox>

            </VBox>

        </HBox>
    </center>
</BorderPane>