<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.LoginController"
            style="-fx-background-color:#F4F9F9;">

    <!-- ===== Top Header (Same Style as Dashboard) ===== -->
    <top>
        <HBox style="-fx-background-color:#0F766E; -fx-padding:18 24; -fx-alignment:center-left;">
            <Label text="HealthConnect"
                   style="-fx-text-fill:white; -fx-font-size:22; -fx-font-weight:bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Patient and Doctor Portal"
                   style="-fx-text-fill:#CCFBF1; -fx-font-size:14;"/>
        </HBox>
    </top>

    <!-- ===== Login Panel ===== -->
    <center>
        <StackPane>
            <VBox spacing="14"
                  maxWidth="420"
                  style="-fx-background-color:white;
                         -fx-background-radius:12;
                         -fx-padding:28;
                         -fx-border-color:#E5E7EB;
                         -fx-border-radius:12;">

                <Label text="Welcome"
                       style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#134E4A;"/>

                <Label text="Log in to your account"
                       style="-fx-font-size:13; -fx-text-fill:#6B7280;"/>

                <!-- Email -->
                <VBox spacing="6">
                    <Label text="Email"
                           style="-fx-font-size:13; -fx-text-fill:#374151;"/>

                    <TextField fx:id="emailField"
                               promptText="name@example.com"
                               style="-fx-background-radius:8; -fx-padding:8;"/>
                </VBox>

                <!-- Password -->
                <VBox spacing="6">
                    <Label text="Password"
                           style="-fx-font-size:13; -fx-text-fill:#374151;"/>

                    <PasswordField fx:id="passwordField"
                                   promptText="••••••••"
                                   style="-fx-background-radius:8; -fx-padding:8;"/>
                </VBox>

                <!-- Error -->
                <Label fx:id="errorLabel"
                       text=""
                       managed="false"
                       visible="false"
                       style="-fx-text-fill:#DC2626; -fx-font-size:12;"/>

                <!-- Login Button -->
                <Button text="Log In"
                        onAction="#onLogin"
                        maxWidth="Infinity"
                        style="-fx-background-color:#0F766E;
                               -fx-text-fill:white;
                               -fx-font-weight:bold;
                               -fx-background-radius:8;
                               -fx-padding:10 16;"/>

                <Button text="Pharmacy Portal"
                        onAction="#onPharmacyPortal"
                        maxWidth="Infinity"
                        style="-fx-background-color:white;
                               -fx-text-fill:#0F766E;
                               -fx-font-weight:bold;
                               -fx-border-color:#14B8A6;
                               -fx-border-radius:8;
                               -fx-background-radius:8;
                               -fx-padding:10 16;"/>

                <!-- Signup Link -->
                <HBox spacing="6" alignment="CENTER">
                    <Label text="No account?"
                           style="-fx-text-fill:#6B7280;"/>

                    <Hyperlink text="Create one"
                               onAction="#onGoSignup"
                               style="-fx-text-fill:#0F766E;"/>
                </HBox>

            </VBox>
        </StackPane>
    </center>

</BorderPane>
