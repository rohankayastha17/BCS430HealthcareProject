<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="rakib.bcs430healthcareproject.PatientDashboardController"
           stylesheets="@app.css">

    <!-- ORIGINAL UI (unchanged) -->
    <BorderPane>

        <!-- Top Header + Tabs -->
        <top>
            <VBox spacing="0">

                <!-- Header -->
                <HBox style="-fx-background-color: #0F766E; -fx-padding: 18 24; -fx-alignment: center-left; -fx-spacing: 15;">

                    <Label text="HealthConnect"
                           style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Label fx:id="welcomeLabel"
                           style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" />

                    <Button fx:id="notificationButton"
                            onAction="#onNotifications"
                            prefWidth="36"
                            prefHeight="36"
                            minWidth="36"
                            minHeight="36"
                            style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 6; -fx-border-color: white; -fx-border-radius: 20; -fx-background-radius: 20;">

                        <graphic>
                            <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                <image>
                                    <Image url="@/rakib/bcs430healthcareproject/bell.png"/>
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>

                    <Button fx:id="logoutButton"
                            text="Logout"
                            onAction="#onLogout"
                            style="-fx-background-color: #14B8A6; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16;" />
                </HBox>

                <!-- Tabs -->
                <HBox style="-fx-background-color: #F0FDFA; -fx-padding: 12 24; -fx-spacing: 10; -fx-border-color: #D1FAE5; -fx-border-width: 0 0 1 0;">

                    <Button text="Dashboard"
                            style="-fx-background-color: #0F766E; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 10 18;" />

                    <Button fx:id="appointmentsButton"
                            text="My Appointments"
                            onAction="#onAppointments"
                            style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 13; -fx-font-weight: bold; -fx-border-color: #14B8A6; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 10 18;" />

                    <Button fx:id="findDoctorButton"
                            text="Find a Doctor"
                            onAction="#onFindDoctor"
                            style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 13; -fx-font-weight: bold; -fx-border-color: #14B8A6; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 10 18;" />

                    <Button fx:id="findHospitalButton"
                            text="Find a Hospital"
                            onAction="#onFindHospital"
                            style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 13; -fx-font-weight: bold; -fx-border-color: #14B8A6; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 10 18;" />

                    <Button fx:id="prescriptionsButton"
                            text="My Prescriptions"
                            onAction="#onPrescriptions"
                            style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 13; -fx-font-weight: bold; -fx-border-color: #14B8A6; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 10 18;" />

                    <Button fx:id="profileButton"
                            text="Edit Profile"
                            onAction="#onProfile"
                            style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 13; -fx-font-weight: bold; -fx-border-color: #14B8A6; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 10 18;" />

                </HBox>

            </VBox>
        </top>

        <!-- Main Content -->
        <center>
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <content>
            <VBox style="-fx-padding: 30; -fx-spacing: 20; -fx-background-color: #F8FAFC;">

                <VBox style="-fx-background-color: linear-gradient(to right, #0F766E, #14B8A6); -fx-background-radius: 12; -fx-padding: 24; -fx-spacing: 8;">
                    <Label text="Patient Dashboard"
                           style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" />
                    <Label text="Welcome to your healthcare portal."
                           style="-fx-text-fill: #CCFBF1; -fx-font-size: 14;" />
                    <Label fx:id="currentDateTimeLabel"
                           text="Today"
                           style="-fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;" />
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-spacing: 10; -fx-border-color: #D1FAE5; -fx-border-radius: 12;">
                    <Label text="Patient Information"
                           style="-fx-text-fill: #0F766E; -fx-font-size: 16; -fx-font-weight: bold;" />

                    <Label fx:id="patientNameLabel"
                           style="-fx-text-fill: #555555; -fx-font-size: 14;" />

                    <Label fx:id="patientEmailLabel"
                           style="-fx-text-fill: #555555; -fx-font-size: 14;" />
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-spacing: 12; -fx-border-color: #D1FAE5; -fx-border-radius: 12;">
                    <HBox style="-fx-alignment: center-left; -fx-spacing: 10;">
                        <Label text="Upcoming Appointments"
                               style="-fx-text-fill: #0F766E; -fx-font-size: 16; -fx-font-weight: bold;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Open My Appointments"
                                onAction="#onAppointments"
                                style="-fx-background-color: #0F766E; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 18; -fx-padding: 8 14;" />
                    </HBox>

                    <Label fx:id="upcomingAppointmentsStatusLabel"
                           text="Loading upcoming appointments..."
                           style="-fx-text-fill: #475569; -fx-font-size: 12;" />

                    <VBox fx:id="upcomingAppointmentsPreviewVBox" spacing="10" />
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-spacing: 12; -fx-border-color: #D1FAE5; -fx-border-radius: 12;">
                    <Label text="Hospital Access"
                           style="-fx-text-fill: #0F766E; -fx-font-size: 16; -fx-font-weight: bold;" />
                    <Label text="Search registered hospital accounts on HealthConnect and view their locations and contact information."
                           wrapText="true"
                           style="-fx-text-fill: #475569; -fx-font-size: 13;" />
                    <Button text="Browse Hospitals"
                            onAction="#onFindHospital"
                            style="-fx-background-color: #0F766E; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 10 18; -fx-max-width: 180;" />
                </VBox>

            </VBox>
            </content>
            </ScrollPane>
        </center>

    </BorderPane>

    <!-- NEW FLOATING BUTTON -->
    <Button fx:id="messageFabButton"
            text="💬"
            onAction="#handleOpenMessages"
            styleClass="fab-message"
            StackPane.alignment="BOTTOM_RIGHT">
        <StackPane.margin>
            <Insets bottom="24" right="24"/>
        </StackPane.margin>
    </Button>

</StackPane>
