<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.HospitalDashboardController"
            stylesheets="@app.css">

    <top>
        <HBox style="-fx-background-color:#0F766E; -fx-padding:18 24; -fx-alignment:center-left;">
            <Label text="HealthConnect"
                   style="-fx-text-fill:white; -fx-font-size:22; -fx-font-weight:bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout"
                    onAction="#onLogout"
                    style="-fx-background-color:#14B8A6; -fx-text-fill:white; -fx-font-size:13; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:8 16;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="18" style="-fx-padding: 28; -fx-background-color: #F8FAFC;">
            <VBox style="-fx-background-color: linear-gradient(to right, #0F766E, #14B8A6); -fx-background-radius: 12; -fx-padding: 24; -fx-spacing: 8;">
                <Label text="Hospital Portal"
                       style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" />
                <Label text="Your hospital account is active in the HealthConnect directory."
                       style="-fx-text-fill: #CCFBF1; -fx-font-size: 14;" />
            </VBox>

            <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-spacing: 10; -fx-border-color: #D1FAE5; -fx-border-radius: 12;">
                <Label fx:id="hospitalNameLabel" style="-fx-text-fill: #0F172A; -fx-font-size: 18; -fx-font-weight: bold;"/>
                <Label fx:id="hospitalEmailLabel" style="-fx-text-fill: #475569; -fx-font-size: 14;"/>
                <Label fx:id="hospitalPhoneLabel" style="-fx-text-fill: #475569; -fx-font-size: 14;"/>
                <Label fx:id="hospitalAddressLabel" style="-fx-text-fill: #475569; -fx-font-size: 14;" wrapText="true"/>
            </VBox>
        </VBox>
    </center>

</BorderPane>
