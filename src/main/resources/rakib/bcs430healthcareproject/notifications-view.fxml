<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.NotificationsController"
            stylesheets="@app.css"
            style="-fx-background-color: #F8FAFC;">

    <top>
        <VBox spacing="0">
            <HBox style="-fx-background-color: #0F766E; -fx-padding: 18 24; -fx-alignment: center-left; -fx-spacing: 12;">
                <Button text="← Back"
                        onAction="#onBack"
                        style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 14;" />

                <Label text="Notifications"
                       style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="Mark All Read"
                        onAction="#onMarkAllRead"
                        style="-fx-background-color: #14B8A6; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 14;" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24;">
            <VBox spacing="6"
                  style="-fx-background-color: linear-gradient(to right, #0F766E, #14B8A6); -fx-background-radius: 14; -fx-padding: 22;">
                <Label text="Your Updates"
                       style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;" />
                <Label text="Appointment changes, messages, prescriptions, and other alerts will appear here."
                       style="-fx-text-fill: #CCFBF1; -fx-font-size: 13;" />
            </VBox>

            <Label fx:id="statusLabel"
                   text=""
                   visible="false"
                   managed="false"
                   style="-fx-text-fill: #64748B; -fx-font-size: 13; -fx-font-weight: bold;" />

            <ListView fx:id="notificationsListView"
                      VBox.vgrow="ALWAYS"
                      prefHeight="520.0"
                      style="-fx-background-color: transparent;" />
        </VBox>
    </center>

</BorderPane>